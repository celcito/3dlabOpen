# Gemini API for AI figures generation
GEMINI_API_KEY=

# Tripo Cloud API (https://studio.tripo3d.ai/settings/api)
TRIPO_API_KEY=

# Optional: override model version (default: v2.0-20240919)
# TRIPO_MODEL_VERSION=v2.0-20240919

# Python service URL (default: localhost)
# IMG2_3D_PY_URL=http://127.0.0.1:8001

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
